package cmd

import (
	"context"
	"fmt"
	"time"

	"github.com/azure/azure-dev/cli/azd/pkg/azdext"
	"github.com/spf13/cobra"
)

func newListenCommand() *cobra.Command {
	return azdext.NewListenCommand(func(host *azdext.ExtensionHost) {
		host.
			WithProjectEventHandler("preprovision", func(ctx context.Context, args *azdext.ProjectEventArgs) error {
				for i := 1; i <= 20; i++ {
					fmt.Printf("%d. Doing important work in extension...\n", i)
					time.Sleep(250 * time.Millisecond)
				}

				return nil
			}).
			WithServiceEventHandler("prepackage", func(ctx context.Context, args *azdext.ServiceEventArgs) error {
				for i := 1; i <= 20; i++ {
					fmt.Printf("%d. Doing important work in extension...\n", i)
					time.Sleep(250 * time.Millisecond)
				}

				return nil
			}, nil)
	})
}
