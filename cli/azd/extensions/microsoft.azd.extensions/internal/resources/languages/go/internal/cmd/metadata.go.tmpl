package cmd

import (
	"github.com/azure/azure-dev/cli/azd/pkg/azdext"
	"github.com/spf13/cobra"
)

func newMetadataCommand(rootCmd *cobra.Command) *cobra.Command {
	return azdext.NewMetadataCommand("1.0", "{{.Metadata.Id}}", func() *cobra.Command {
		return rootCmd
	})
}
