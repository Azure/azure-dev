              "name": "azure.ai.agent",
              "type": "service-target",
              "description": "Deploys agents to the Foundry Agent Service"
            },
            {
              "name": "azure.ai.project",
              "type": "service-target",
              "description": "Registers Foundry project service entries so azd up/deploy succeed"
            },
            {
              "name": "azure.ai.connection",
