    {
      "id": "azure.ai.agents",
      "namespace": "ai.agent",
      "displayName": "Foundry agents (Preview)",
      "description": "Ship agents with Microsoft Foundry from your terminal. (Preview)",
      "versions": [
        {
          "version": "0.1.42-preview.nightly.6499092",
          "requiredAzdVersion": ">1.25.2",
          "capabilities": [
            "custom-commands",
